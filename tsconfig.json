{
    "compilerOptions": {
        "target": "ES2022",
        "lib": [
            "ES2022"
        ],
        "module": "ES2022",
        "moduleResolution": "bundler",
        "strict": true,
        "noUncheckedIndexedAccess": true,
        "types": [
            "@cloudflare/workers-types"
        ],
        "jsx": "react-jsx",
        "jsxImportSource": "hono/jsx"
    },
    "include": [
        "src/**/*.ts",
        "worker-configuration.d.ts"
    ]
}